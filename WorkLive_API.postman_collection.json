          "name": "Mark Notification as Read",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/notifications/{{notificationId}}/read", "host": ["{{baseUrl}}"], "path": ["api", "v1", "notifications", "{{notificationId}}", "read"] },
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "Delete Notification",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/v1/notifications/{{notificationId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "notifications", "{{notificationId}}"] }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get Reviews for a Vendor",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/reviews?revieweeId={{vendorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reviews"],
              "query": [
                { "key": "revieweeId", "value": "{{vendorId}}", "description": "Get reviews received by this user" },
                { "key": "reviewerId", "value": "", "description": "Get reviews written by this user", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Check if User Reviewed a Vendor",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/reviews?reviewerId={{userId}}&revieweeId={{vendorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reviews"],
              "query": [
                { "key": "reviewerId", "value": "{{userId}}" },
                { "key": "revieweeId", "value": "{{vendorId}}" }
              ]
            }
          }
        },
        {
          "name": "Submit Review",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/reviews", "host": ["{{baseUrl}}"], "path": ["api", "v1", "reviews"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"revieweeId\": \"{{vendorId}}\",\n  \"rating\": 5,\n  \"comment\": \"Excellent service! Fixed my laptop screen in 24 hours. Highly recommended.\",\n  \"type\": \"user_to_vendor\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('reviewId', res.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Review",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/reviews/{{reviewId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "reviews", "{{reviewId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4,\n  \"comment\": \"Good service overall. Minor delay but quality was great.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Report a User",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/reports", "host": ["{{baseUrl}}"], "path": ["api", "v1", "reports"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reportedId\": \"{{vendorId}}\",\n  \"reportedType\": \"user\",\n  \"reason\": \"Fraudulent activity\",\n  \"details\": \"This vendor collected payment but never showed up to do the work.\"\n}"
            }
          }
        },
        {
          "name": "Report a Request",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/reports", "host": ["{{baseUrl}}"], "path": ["api", "v1", "reports"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reportedId\": \"{{requestId}}\",\n  \"reportedType\": \"request\",\n  \"reason\": \"Inappropriate content\",\n  \"details\": \"This service request contains offensive language.\"\n}"
            }
          }
        },
        {
          "name": "Report an Offer",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/reports", "host": ["{{baseUrl}}"], "path": ["api", "v1", "reports"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reportedId\": \"{{offerId}}\",\n  \"reportedType\": \"offer\",\n  \"reason\": \"Misleading offer\",\n  \"details\": \"The offer price is intentionally misleading.\"\n}"
            }
          }
        }
      ]
    }
  ]
}
